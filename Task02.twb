      <aliases enabled='yes' />
      <column caption='Anomaly Flag' datatype='integer' name='[AnomalyFlag]' role='measure' type='quantitative' />
      <column caption='overall churn rate' datatype='real' name='[Calculation_0394467533049856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ChurnFlag]) / COUNT([customerID])' />
      </column>
      <column caption='Tenure monthly' datatype='integer' name='[Calculation_0394467535491073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; OR [Churn] = &quot;No&quot; THEN [tenure] END' />
      </column>
      <column caption='revenue at risk' datatype='real' name='[Calculation_0394467536195586]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] END' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_0394467536805891]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ChurnFlag]) / COUNT([customerID])' />
      </column>
      <column caption='Tenure bucket' datatype='string' name='[Calculation_0394467539402756]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0–12 months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;13–24 months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 36 THEN &quot;25–36 months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;37–48 months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 60 THEN &quot;49–60 months&quot;&#13;&#10;ELSE &quot;60+ months&quot;&#13;&#10;END' />
      </column>
